<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Proposta {{ $proposal->number }}</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Segoe UI',Arial,sans-serif;font-size:13px;color:#1a1a1a;background:#fff;}
.page{max-width:900px;margin:0 auto;padding:40px;}
/* Header */
.header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:32px;padding-bottom:24px;border-bottom:3px solid #1e40af;}
.logo img{max-height:60px;max-width:200px;object-fit:contain;}
.logo-text{font-size:20px;font-weight:700;color:#1e40af;}
.proposal-meta{text-align:right;}
.proposal-meta .number{font-size:18px;font-weight:700;color:#1e40af;}
.proposal-meta .date{font-size:11px;color:#6b7280;margin-top:4px;}
.badge-status{display:inline-block;padding:3px 10px;border-radius:9999px;font-size:11px;font-weight:600;margin-top:6px;}
.badge-draft{background:#fef3c7;color:#92400e;}
.badge-sent{background:#dbeafe;color:#1e40af;}
.badge-approved{background:#d1fae5;color:#065f46;}
/* Cloud Banner */
.cloud-banner{background:linear-gradient(135deg,#1e3a8a 0%,#3b82f6 50%,#06b6d4 100%);color:#fff;border-radius:12px;padding:24px 28px;margin-bottom:28px;position:relative;overflow:hidden;}
.cloud-banner::before{content:'☁';position:absolute;right:20px;top:50%;transform:translateY(-50%);font-size:80px;opacity:0.1;}
.cloud-banner h2{font-size:18px;font-weight:700;margin-bottom:6px;}
.cloud-banner p{font-size:12px;opacity:0.9;line-height:1.6;max-width:600px;}
.cloud-features{display:flex;gap:20px;margin-top:14px;flex-wrap:wrap;}
.cloud-features span{font-size:11px;background:rgba(255,255,255,0.15);padding:4px 10px;border-radius:6px;}
/* Parties */
.parties{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:28px;}
.party-box{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:16px;}
.party-box h4{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#6b7280;margin-bottom:8px;}
.party-box .name{font-size:14px;font-weight:700;color:#1e40af;margin-bottom:4px;}
.party-box .detail{font-size:11px;color:#374151;line-height:1.6;}
/* Items Table */
.section-title{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#6b7280;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid #e5e7eb;}
table{width:100%;border-collapse:collapse;margin-bottom:24px;}
thead th{background:#1e40af;color:#fff;text-align:left;padding:8px 12px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.04em;}
thead th:last-child{text-align:right;}
tbody tr:nth-child(even){background:#f8fafc;}
tbody td{padding:9px 12px;font-size:12px;border-bottom:1px solid #e5e7eb;vertical-align:top;}
tbody td:last-child{text-align:right;font-weight:600;color:#1e40af;white-space:nowrap;}
tbody td .desc{font-size:10px;color:#6b7280;margin-top:2px;}
tfoot td{padding:8px 12px;font-size:12px;font-weight:600;border-top:2px solid #e5e7eb;}
tfoot tr.total td{background:#1e40af;color:#fff;font-size:14px;font-weight:700;}
tfoot tr.total td:last-child{font-size:16px;}
/* Validity */
.validity-box{background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:12px 16px;margin-bottom:20px;display:flex;align-items:center;gap:10px;}
.validity-box .icon{font-size:18px;}
.validity-box p{font-size:12px;color:#1e40af;}
.validity-box strong{font-weight:700;}
/* Notes */
.notes-box{background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:14px 16px;margin-bottom:24px;}
.notes-box h4{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#6b7280;margin-bottom:8px;}
.notes-box p{font-size:12px;color:#374151;line-height:1.7;white-space:pre-wrap;}
/* Terms */
.terms{font-size:10px;color:#9ca3af;line-height:1.6;border-top:1px solid #e5e7eb;padding-top:16px;margin-top:24px;}
/* Footer */
.footer{margin-top:32px;padding-top:20px;border-top:2px solid #e5e7eb;display:flex;justify-content:space-between;align-items:flex-end;}
.footer .signature{text-align:center;min-width:200px;}
.footer .signature .line{border-top:1px solid #374151;padding-top:6px;font-size:11px;color:#374151;margin-top:40px;}
/* Print button */
.print-btn{display:inline-flex;align-items:center;gap:8px;background:#1e40af;color:#fff;border:none;border-radius:8px;padding:10px 20px;font-size:13px;font-weight:600;cursor:pointer;margin-bottom:24px;}
.print-btn:hover{background:#1e3a8a;}
@media print{
  .print-btn{display:none!important;}
  .page{padding:20px;}
  body{font-size:12px;}
}
</style>
</head>
<body>
<div class="page">

  {{-- Print button --}}
  <button class="print-btn" onclick="window.print()">
    🖨️ Imprimir / Salvar PDF
  </button>

  {{-- Header --}}
  <div class="header">
    <div class="logo">
      @if($proposal->partner->logo)
        <img src="{{ Storage::url($proposal->partner->logo) }}" alt="{{ $proposal->partner->trade_name }}"/>
      @else
        <div class="logo-text">{{ $proposal->partner->trade_name ?? $proposal->partner->company_name }}</div>
      @endif
    </div>
    <div class="proposal-meta">
      <div class="number">{{ $proposal->number }}</div>
      <div class="date">Emitida em {{ $proposal->created_at->format('d/m/Y') }}</div>
      @if($proposal->valid_until)
        <div class="date">Válida até {{ $proposal->valid_until->format('d/m/Y') }}</div>
      @endif
      <div>
        @php $statusMap=['draft'=>['Rascunho','badge-draft'],'sent'=>['Enviada','badge-sent'],'approved'=>['Aprovada','badge-approved'],'rejected'=>['Rejeitada','badge-draft'],'expired'=>['Expirada','badge-draft']]; $st=$statusMap[$proposal->status]??['Rascunho','badge-draft']; @endphp
        <span class="badge-status {{ $st[1] }}">{{ $st[0] }}</span>
      </div>
    </div>
  </div>

  {{-- Cloud Banner --}}
  <div class="cloud-banner">
    <h2>☁ Infraestrutura em Nuvem — {{ $proposal->title }}</h2>
    <p>Esta proposta apresenta os recursos de computação em nuvem dimensionados para sua empresa, com alta disponibilidade, segurança e escalabilidade. Todos os valores incluem operação, monitoramento e suporte técnico especializado.</p>
    <div class="cloud-features">
      <span>✓ Alta Disponibilidade</span>
      <span>✓ Backup Automático</span>
      <span>✓ Suporte Técnico</span>
      <span>✓ Monitoramento 24/7</span>
      <span>✓ Escalabilidade</span>
    </div>
  </div>

  {{-- Parties --}}
  <div class="parties">
    <div class="party-box">
      <h4>Fornecedor</h4>
      <div class="name">{{ $proposal->partner->trade_name ?? $proposal->partner->company_name }}</div>
      <div class="detail">
        @if($proposal->partner->cnpj) CNPJ: {{ $proposal->partner->cnpj }}<br/>@endif
        @if($proposal->partner->email) {{ $proposal->partner->email }}<br/>@endif
        @if($proposal->partner->phone) {{ $proposal->partner->phone }}<br/>@endif
        @if($proposal->partner->city) {{ $proposal->partner->city }}{{ $proposal->partner->state ? ' — '.$proposal->partner->state : '' }}@endif
      </div>
    </div>
    <div class="party-box">
      <h4>Cliente</h4>
      <div class="name">{{ $proposal->customer->trade_name ?? $proposal->customer->name }}</div>
      <div class="detail">
        @if($proposal->customer->document) {{ strtoupper($proposal->customer->document_type ?? 'CNPJ') }}: {{ $proposal->customer->document_formatted }}<br/>@endif
        @if($proposal->customer->email) {{ $proposal->customer->email }}<br/>@endif
        @if($proposal->customer->phone) {{ $proposal->customer->phone }}<br/>@endif
        @if($proposal->customer->city) {{ $proposal->customer->city }}{{ $proposal->customer->state ? ' — '.$proposal->customer->state : '' }}@endif
      </div>
    </div>
  </div>

  {{-- Validity --}}
  @if($proposal->valid_until)
  <div class="validity-box">
    <span class="icon">📅</span>
    <p>Esta proposta é válida até <strong>{{ $proposal->valid_until->format('d/m/Y') }}</strong>. Após essa data os valores poderão ser reajustados.</p>
  </div>
  @endif

  {{-- Items --}}
  <div class="section-title">Serviços Contratados</div>
  <table>
    <thead>
      <tr>
        <th style="width:50%">Serviço / Produto</th>
        <th style="width:30%">Descrição</th>
        <th style="width:10%;text-align:center">Qtd</th>
        <th style="width:10%">Valor/Mês</th>
      </tr>
    </thead>
    <tbody>
      @foreach($proposal->items as $item)
      <tr>
        <td>
          <strong>{{ $item->name }}</strong>
          @if($item->description)<div class="desc">{{ $item->description }}</div>@endif
        </td>
        <td><div class="desc">{{ $item->description ?? '—' }}</div></td>
        <td style="text-align:center">{{ (int)$item->quantity }}</td>
        <td>R$ {{ number_format($item->unit_price, 2, ',', '.') }}</td>
      </tr>
      @endforeach
    </tbody>
    <tfoot>
      @if($proposal->discount > 0)
      <tr>
        <td colspan="3" style="text-align:right;color:#6b7280;">Subtotal</td>
        <td style="text-align:right;color:#6b7280;">R$ {{ number_format($proposal->subtotal,2,',','.') }}</td>
      </tr>
      <tr>
        <td colspan="3" style="text-align:right;color:#dc2626;">Desconto</td>
        <td style="text-align:right;color:#dc2626;">- R$ {{ number_format($proposal->discount,2,',','.') }}</td>
      </tr>
      @endif
      <tr class="total">
        <td colspan="3" style="text-align:right;">Total Mensal</td>
        <td style="text-align:right;">R$ {{ number_format($proposal->total,2,',','.') }}/mês</td>
      </tr>
    </tfoot>
  </table>

  {{-- Notes --}}
  @if($proposal->notes)
  <div class="notes-box">
    <h4>Observações</h4>
    <p>{{ $proposal->notes }}</p>
  </div>
